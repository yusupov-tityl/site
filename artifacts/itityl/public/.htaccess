# SPA routing — любой путь без физического файла отдаёт index.html,
# а wouter уже на клиенте разруливает по src/App.tsx.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Force HTTPS
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Long-term cache на хэшированные ассеты (Vite добавляет hash в имя файла
# — безопасно кэшировать год).
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|webp|jpg|jpeg|png|svg|mp4|webm|mp3)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html никогда не кэшируем — он меняется при каждом деплое
  <FilesMatch "^(index\.html|sitemap\.xml|robots\.txt)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  # Security headers
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Gzip/Brotli compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml application/xml
</IfModule>

# Правильные MIME для WebM / WebP
<IfModule mod_mime.c>
  AddType video/webm .webm
  AddType image/webp .webp
  AddType font/woff2 .woff2
</IfModule>

# 404 → SPA (пусть клиент покажет NotFound компонент)
ErrorDocument 404 /index.html
